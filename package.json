{
  "name": "modern-crm",
  "private": true,
  "version": "1.0.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev --workspace=apps/api\" \"npm:dev --workspace=apps/web\"",
    "build": "npm run build --workspace=apps/api && npm run build --workspace=apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
